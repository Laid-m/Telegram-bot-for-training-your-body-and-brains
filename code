

from aiogram import Bot, Dispatcher, executor, types
from aiogram.types import ReplyKeyboardMarkup, KeyboardButton
from random import choice

bot = Bot(token="TOKEN")
dp = Dispatcher(bot)

# меню
menu = ReplyKeyboardMarkup(resize_keyboard=True)

but1 = KeyboardButton("Задание")
but2 = KeyboardButton("Готово")
but3 = KeyboardButton("Статистика")
but4 = KeyboardButton("Усложнение")

menu.add(but1, but2).add(but3, but4)

# данные
tasks = [
    "10 отжиманий",
    "10 приседаний",
    "10 скручиваний на пресс",
    "читать книгу",
    "выучить что-то новое"
]

tasks2 = [
    "20 отжиманий",
    "20 приседаний",
    "20 скручиваний на пресс",
    "особое задание от Тайлера Дердена: начни изучать фондовый рынок"
]

done_count = 0


@dp.message_handler(commands=['start'])
async def start(message: types.Message):
    await message.answer(
        f"привет {message.from_user.first_name}  готов стать лучше?",
        reply_markup=menu
    )


@dp.message_handler()
async def menus(message: types.Message):
    global done_count

    if message.text == "Задание":
        await message.answer(choice(tasks))

    elif message.text == "Готово":
        done_count += 1
        await message.answer(f"красава  выполнено: {done_count}")

    elif message.text == "Статистика":
        await message.answer(f"твоя статистика: {done_count} заданий")

    elif message.text == "Усложнение":
        await message.answer(choice(tasks2))


@dp.message_handler(commands=['task'])
async def task(message: types.Message):
    await message.answer(choice(tasks))


@dp.message_handler(commands=['task2'])
async def task2(message: types.Message):
    await message.answer(choice(tasks2))


@dp.message_handler(commands=['done'])
async def done(message: types.Message):
    global done_count
    done_count += 1
    await message.answer(f"йоо ты красавчик  завершил {done_count} заданий")


@dp.message_handler(commands=['stats'])
async def stats(message: types.Message):
    await message.answer(f"твоя статистика: {done_count} заданий")


if __name__ == '__main__':
    executor.start_polling(dp, skip_updates=True)